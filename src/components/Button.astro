---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost" | "light";
  size?: "md" | "lg";
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  class: className = "",
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-full font-body font-semibold tracking-wide transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2";

const sizes = {
  md: "px-6 py-3 text-sm",
  lg: "px-8 py-4 text-sm sm:text-base",
};

const variants = {
  primary:
    "bg-clay text-cream shadow-soft hover:bg-clay-deep focus-visible:outline-clay-deep",
  secondary:
    "border border-sand bg-cream/80 text-ink backdrop-blur-sm hover:border-clay/40 hover:bg-cream",
  ghost: "text-clay-deep hover:bg-clay/10",
  light:
    "bg-cream text-forest hover:bg-linen focus-visible:outline-cream",
};

const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<a
  href={href}
  class:list={[base, sizes[size], variants[variant], className]}
  rel={rel}
  target={target}
>
  <slot />
</a>
