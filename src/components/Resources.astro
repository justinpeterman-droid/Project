---
import { resources } from "../data/site";

const icons: Record<string, string> = {
  download: "M12 3v12m0 0l4-4m-4 4l-4-4M4 19h16",
  app: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z",
  form: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
};

const accents: Record<
  string,
  {
    label: string;
    stripe: string;
    icon: string;
    tag: string;
    cta: string;
    hover: string;
  }
> = {
  download: {
    label: "Journal",
    stripe: "from-sage-deep via-sage to-sage/60",
    icon: "bg-sage/25 text-sage-deep ring-sage/30 group-hover:bg-sage/35 group-hover:ring-sage/50",
    tag: "text-sage-deep",
    cta: "bg-sage/15 text-sage-deep group-hover:bg-sage/25",
    hover: "hover:border-sage/45 hover:shadow-[0_18px_48px_rgba(91,106,86,0.14)]",
  },
  app: {
    label: "Client app",
    stripe: "from-clay-deep via-clay to-clay/70",
    icon: "bg-clay/20 text-clay-deep ring-clay/25 group-hover:bg-clay/30 group-hover:ring-clay/40",
    tag: "text-clay-deep",
    cta: "bg-clay/15 text-clay-deep group-hover:bg-clay/25",
    hover: "hover:border-clay/40 hover:shadow-[0_18px_48px_rgba(189,123,83,0.16)]",
  },
  form: {
    label: "Submission",
    stripe: "from-gold via-clay/80 to-gold/70",
    icon: "bg-gold/25 text-loam ring-gold/35 group-hover:bg-gold/35 group-hover:ring-gold/50",
    tag: "text-loam",
    cta: "bg-gold/20 text-loam group-hover:bg-gold/30",
    hover: "hover:border-gold/50 hover:shadow-[0_18px_48px_rgba(194,162,76,0.18)]",
  },
};
---

<section
  id="resources"
  class="scroll-mt-24 relative overflow-hidden bg-linen py-24 sm:py-32"
  aria-labelledby="resources-heading"
>
  <div
    class="pointer-events-none absolute inset-0 glow-warm opacity-70"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-sage/15 blur-3xl"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -right-16 bottom-0 h-64 w-64 rounded-full bg-clay/12 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-5 sm:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="reveal eyebrow">Resources</p>
      <h2
        id="resources-heading"
        class="reveal reveal-delay-1 mt-4 font-display text-3xl text-balance text-ink sm:text-4xl md:text-5xl"
      >
        Tools for the journey between sessions
      </h2>
      <p class="reveal reveal-delay-2 mt-6 text-pretty text-lg text-muted">
        Journals, client spaces, and forms — designed to support your flow at your
        own pace.
      </p>
      <div class="reveal reveal-delay-2 hairline mx-auto mt-8 max-w-xs" aria-hidden="true"></div>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        resources.map((item, i) => {
          const accent = accents[item.kind] ?? accents.form;
          return (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "reveal group relative flex flex-col overflow-hidden rounded-2xl border border-sand/80 bg-cream shadow-soft transition duration-300 hover:-translate-y-1",
                accent.hover,
                `reveal-delay-${i + 1}`,
              ]}
            >
              <div
                class:list={[
                  "h-1.5 bg-gradient-to-r",
                  accent.stripe,
                ]}
                aria-hidden="true"
              ></div>

              <div class="flex flex-1 flex-col p-8">
                <div class="flex items-start justify-between gap-3">
                  <span
                    class:list={[
                      "inline-flex h-14 w-14 items-center justify-center rounded-2xl ring-1 transition duration-300",
                      accent.icon,
                    ]}
                  >
                    <svg
                      class="h-7 w-7"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.5"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d={icons[item.kind] ?? icons.form}
                      />
                    </svg>
                  </span>
                  <span
                    class:list={[
                      "rounded-full bg-canvas/90 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.18em]",
                      accent.tag,
                    ]}
                  >
                    {accent.label}
                  </span>
                </div>

                <h3 class="mt-6 font-display text-xl leading-snug text-ink">
                  {item.title}
                </h3>
                <p class="mt-3 flex-1 text-pretty text-sm leading-relaxed text-muted">
                  {item.description}
                </p>

                <span
                  class:list={[
                    "mt-8 inline-flex w-fit items-center gap-2 rounded-full px-4 py-2.5 text-sm font-semibold transition duration-300",
                    accent.cta,
                  ]}
                >
                  {item.cta}
                  <span
                    aria-hidden="true"
                    class="transition duration-300 group-hover:translate-x-1"
                  >
                    →
                  </span>
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
