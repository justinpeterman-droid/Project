---
import { site, nav, booking } from "../data/site";
import Button from "./Button.astro";
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-sand/60 bg-canvas/85 backdrop-blur-md"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 sm:px-8"
  >
    <a href="/" class="group flex min-w-0 flex-col gap-0.5">
      <span
        class="font-display text-lg leading-none tracking-tight text-ink sm:text-xl"
        >{site.name}</span
      >
      <span class="hidden text-[0.65rem] font-medium uppercase tracking-[0.2em] text-muted sm:block"
        >{site.practitioner} · {site.credentials}</span
      >
    </a>

    <nav
      class="hidden items-center gap-7 lg:flex"
      aria-label="Primary"
    >
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-muted transition hover:text-ink"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <Button
        href={booking.url}
        variant="primary"
        size="md"
        external
        class="hidden sm:inline-flex"
      >
        {booking.discovery.short}
      </Button>
      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-sand bg-cream/90 text-ink lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-sand/60 bg-canvas/95 px-5 py-5 backdrop-blur-md lg:hidden"
    hidden
  >
    <nav class="flex flex-col gap-1" aria-label="Mobile">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-lg px-3 py-3 text-base font-medium text-loam hover:bg-linen"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={booking.url}
        class="mt-3 rounded-full bg-clay px-6 py-3.5 text-center text-sm font-semibold text-cream"
        target="_blank"
        rel="noopener noreferrer"
      >
        {booking.discovery.label}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(!open));
      menu.hidden = open;
    });
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        menu.hidden = true;
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>
