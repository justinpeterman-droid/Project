---
import { about, contact, credentialBadges } from "../data/site";
import Button from "./Button.astro";
import Picture from "./Picture.astro";
---

<section
  id="about"
  class="scroll-mt-24 bg-linen py-24 sm:py-32"
  aria-labelledby="about-heading"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:gap-10 lg:gap-14">
      <figure
        class="reveal mx-auto w-44 shrink-0 overflow-hidden rounded-2xl border border-sand bg-cream shadow-lift sm:w-48 md:mx-0 md:w-52 lg:w-56"
      >
        <Picture
          base={about.image.base}
          alt={about.image.alt}
          class="aspect-[3/4] w-full object-cover object-[center_15%]"
          loading="eager"
        />
        <figcaption
          class="border-t border-sand/80 bg-cream/95 px-4 py-3 text-center font-display text-sm italic leading-snug text-clay-deep sm:text-base"
        >
          {about.closing}
        </figcaption>
      </figure>

      <div class="min-w-0 flex-1">
        <p class="reveal eyebrow">About</p>
        <h2
          id="about-heading"
          class="reveal reveal-delay-1 mt-4 font-display text-3xl text-balance text-ink sm:text-4xl"
        >
          {about.heading}
        </h2>

        <blockquote
          class="reveal reveal-delay-2 mt-8 border-l-2 border-gold/60 pl-6 font-display text-xl italic leading-relaxed text-loam sm:text-2xl"
        >
          "{about.quote}"
        </blockquote>

        {
          about.body.map((para, i) => (
            <p
              class:list={[
                "reveal mt-6 text-pretty leading-relaxed text-muted",
                `reveal-delay-${i + 3}`,
              ]}
            >
              {para}
            </p>
          ))
        }

        <div class="reveal reveal-delay-4 mt-10">
          <p class="eyebrow mb-4">Credentials &amp; training</p>
          <ul
            class="mb-8 flex flex-wrap items-center justify-center gap-6 sm:justify-start md:gap-8"
            aria-label="Certification badges"
          >
            {
              credentialBadges.map((badge) => (
                <li>
                  <img
                    src={`${badge.base}.png`}
                    alt={badge.alt}
                    width="96"
                    height="96"
                    loading="lazy"
                    class="h-20 w-20 object-contain opacity-95 transition hover:opacity-100 sm:h-24 sm:w-24"
                  />
                </li>
              ))
            }
          </ul>
          <ul class="grid gap-3 sm:grid-cols-2">
            {
              about.credentials.map((cred) => (
                <li class="flex gap-3 rounded-xl border border-sand/60 bg-cream px-4 py-3 text-sm text-loam">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-clay" aria-hidden="true"></span>
                  {cred}
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="reveal reveal-delay-5 mt-10 rounded-2xl border border-clay/25 bg-gradient-to-br from-cream via-cream to-linen p-6 shadow-soft sm:p-8"
        >
          <p class="font-display text-xl text-ink sm:text-2xl">
            Ready to connect?
          </p>
          <p class="mt-2 max-w-md text-sm leading-relaxed text-muted">
            Reach out directly — Ashley typically responds within one business
            day.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <Button href={contact.emailHref} variant="primary" size="lg">
              <svg
                class="h-4 w-4 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              Email Ashley
            </Button>
            <Button href={contact.phoneHref} variant="forest" size="lg">
              <svg
                class="h-4 w-4 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              {contact.phone}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
