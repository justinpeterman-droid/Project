---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
---

<Layout path="/">
  <main id="main" class="mx-auto max-w-3xl px-6 py-32 text-center">
    <p class="eyebrow">Foundation smoke test</p>
    <h1 class="mt-4 text-5xl text-balance">{site.name}</h1>
    <p class="mt-6 font-display text-2xl italic text-muted">{site.tagline}</p>
    <p class="mt-10">
      <a
        href={site.url}
        class="inline-flex items-center gap-2 rounded-full bg-clay px-7 py-3.5 font-body text-sm font-semibold tracking-wide text-cream shadow-soft transition hover:bg-clay-deep"
        >Primary button preview</a
      >
    </p>
  </main>
</Layout>
