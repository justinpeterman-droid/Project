---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Compliance from "../components/Compliance.astro";
import { site, contact, legal } from "../data/site";
---

<Layout title="Privacy" path="/privacy" description={`Privacy practices for ${site.name}.`}>
  <Header />
  <main id="main" class="mx-auto max-w-3xl px-5 pb-24 pt-32 sm:px-8">
    <p class="eyebrow">Legal</p>
    <h1 class="mt-4 font-display text-4xl text-ink">Privacy</h1>
    <p class="mt-6 text-muted">
      This page will be expanded with full privacy policy language before public
      launch. For questions about your information, contact Ashley directly.
    </p>
    <ul class="mt-8 space-y-2 text-sm text-loam">
      <li>
        Email: <a href={contact.emailHref} class="text-clay-deep underline"
          >{contact.email}</a
        >
      </li>
      <li>
        Phone: <a href={contact.phoneHref} class="text-clay-deep underline"
          >{contact.phone}</a
        >
      </li>
    </ul>
    <div class="mt-12">
      <Compliance />
    </div>
    <p class="mt-8 text-xs text-faint">{legal.copyright}</p>
  </main>
  <Footer />
</Layout>
